---
import Container from '../components/Container.astro';
import MenuCard from '../components/MenuCard.astro';
---

<section class="py-20 md:py-28">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="font-display text-4xl md:text-5xl text-ink-black">
        Stay for the BKT. Come back for everything else.
      </h2>
      <p class="text-soy-brown text-lg mt-4">
        The cheese bak kut teh gets the headlines. The creamy chicken cutlet spaghetti and honey milk longan drink keep regulars coming twice a week.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <MenuCard
        name="Creamy Chicken Cutlet Spaghetti"
        description="Crispy chicken cutlet over spaghetti in rich cream sauce. Fan favourite."
        price="RM 9.90"
        image="https://images.unsplash.com/photo-1555949258-eb67b1ef0ceb?w=800&h=600&fit=crop"
      />
      <MenuCard
        name="Honey Milk Longan"
        description="Our signature drink — fresh longan in honey milk. Refreshing and mildly sweet."
        price="RM 5.50"
        image="https://images.unsplash.com/photo-1544145945-f90425340c7e?w=800&h=600&fit=crop"
      />
      <MenuCard
        name="Dry Bak Kut Teh"
        description="Braised pork in dark soy with dried chilies and lady fingers. Intense."
        price="RM 11.90"
        image="https://images.unsplash.com/photo-1544025162-d76694265947?w=800&h=600&fit=crop"
      />
      <MenuCard
        name="Western Mains"
        description="Chicken chop, bolognese, and more. Big portions, student prices."
        price="From RM 8.50"
        image="https://images.unsplash.com/photo-1432139555190-58524dae6a55?w=800&h=600&fit=crop"
      />
    </div>
  </Container>
</section>
