---
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import siteData from '../data/site.json';
---

<section class="py-20 md:py-28 bg-cream">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
      <!-- Map -->
      <div class="aspect-video rounded-2xl overflow-hidden bg-soy-brown/10">
        <iframe
          src={siteData.googleMapsEmbedUrl}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="B.A.J Restaurant location on Google Maps"
          class="w-full h-full"
        ></iframe>
      </div>

      <!-- Info -->
      <div>
        <h2 class="font-display text-3xl md:text-4xl text-ink-black mb-4">Find Us</h2>
        <p class="text-soy-brown text-lg mb-6">
          {siteData.address}
        </p>
        <div class="space-y-2 text-soy-brown mb-6">
          <p><span class="font-semibold text-ink-black">Phone:</span> {siteData.phone}</p>
          <p><span class="font-semibold text-ink-black">Hours:</span></p>
          <div class="pl-4 space-y-1 text-sm">
            <p>Mon–Sat: 8:00 AM – 3:00 PM, 5:30 PM – 10:00 PM</p>
            <p>Sun: Closed</p>
          </div>
        </div>
        <Button href="/story" variant="outline">How to find the stairs →</Button>
      </div>
    </div>
  </Container>
</section>
