---
import Container from '../components/Container.astro';
import MenuCard from '../components/MenuCard.astro';
---

<section class="py-20 md:py-28 bg-soft-white">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="font-display text-4xl md:text-5xl text-deep-navy">
        The ones every monster orders.
      </h2>
      <p class="text-slate text-lg mt-4">
        Even the smallest table leaves with a stack.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <MenuCard
        name="Salmon Nigiri"
        description="Melt-in-the-mouth fresh salmon over seasoned rice. Our most-ordered."
        price="RM 3.90"
        image="https://images.unsplash.com/photo-1579871494447-9811cf80d66c?w=800&h=600&fit=crop"
        tier="red"
        signature={true}
      />
      <MenuCard
        name="Tempura Soba"
        description="Hot buckwheat noodles with crispy tempura shrimp. Celebrated for flavor."
        price="RM 5.90"
        image="https://images.unsplash.com/photo-1614777986387-015c2a89b696?w=800&h=600&fit=crop"
        tier="gold"
        signature={true}
      />
      <MenuCard
        name="Unagi Maki"
        description="Grilled eel with cucumber, wrapped in nori and rice. Sweet and savory."
        price="RM 3.90"
        image="https://images.unsplash.com/photo-1563612116625-3012372fccce?w=800&h=600&fit=crop"
        tier="red"
      />
      <MenuCard
        name="Chuka Kurage"
        description="Seasoned jellyfish salad. Crunchy, tangy, and refreshing."
        price="RM 1.90"
        image="https://images.unsplash.com/photo-1606923829579-0cb981a83e2e?w=800&h=600&fit=crop"
        tier="green"
      />
    </div>
  </Container>
</section>
