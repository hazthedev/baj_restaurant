---
import Container from '../components/Container.astro';
---

<section class="py-20 md:py-28 bg-bkt-brown relative overflow-hidden">
  <div class="absolute inset-0 opacity-20">
    <img
      src="https://images.unsplash.com/photo-1555529733-0e670560f7e1?w=1200&h=800&fit=crop"
      alt="Wet market atmosphere at dusk"
      class="w-full h-full object-cover"
      loading="lazy"
    />
  </div>
  <Container className="relative z-10">
    <div class="max-w-3xl mx-auto text-center">
      <blockquote class="font-display text-3xl md:text-4xl lg:text-5xl text-cream leading-tight">
        "Above a wet market in Setapak. We know — that's the fun part."
      </blockquote>
      <p class="text-cream/70 text-lg mt-6 leading-relaxed max-w-xl mx-auto">
        The market closes by evening. The restaurant goes till 10. Take the stairs up to the 1st floor, follow the smell of cheese bak kut teh.
      </p>
    </div>
  </Container>
</section>
