---
import Container from '../components/Container.astro';
import Eyebrow from '../components/Eyebrow.astro';
import PressBadge from '../components/PressBadge.astro';
import pressData from '../data/press.json';
---

<section class="py-20 md:py-28 bg-cream">
  <Container>
    <div class="text-center mb-12">
      <Eyebrow>WHAT WE'RE FAMOUS FOR</Eyebrow>
      <h2 class="font-display text-4xl md:text-5xl text-ink-black mt-2">Cheese Bak Kut Teh.</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center mb-12">
      <!-- Image -->
      <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-bkt-brown/10">
        <img
          src="https://images.unsplash.com/photo-1607301406259-dfb34844a70c?w=800&h=600&fit=crop"
          alt="Close-up of Cheese Bak Kut Teh — melted cheese stretching over pork chunks and okra in herbal broth"
          class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
          loading="lazy"
        />
      </div>

      <!-- Story -->
      <div>
        <p class="text-ink-black text-lg md:text-xl leading-relaxed">
          Pork chunks. Fresh okra. Herbal broth. Melted cheese on top.
        </p>
        <p class="text-soy-brown text-lg mt-4 leading-relaxed">
          We started serving it in 2018 and the food bloggers haven't stopped talking. Try it once — you'll get it.
        </p>
        <div class="mt-6 inline-flex items-center gap-2 bg-cheese-yellow/20 text-bkt-brown text-sm font-medium px-3 py-1.5 rounded-full">
          <span>🧀</span>
          <span>Invented here in 2018</span>
        </div>
      </div>
    </div>

    <!-- Press Badges -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 max-w-4xl mx-auto">
      {pressData.slice(0, 3).map((press) => (
        <PressBadge
          name={press.name}
          quote={press.quote}
          url={press.url}
        />
      ))}
    </div>
  </Container>
</section>
