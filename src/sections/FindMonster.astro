---
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
import siteData from '../data/site.json';
---

<section class="py-20 md:py-28 bg-pure-white">
  <Container>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
      <!-- Map -->
      <div class="aspect-video rounded-2xl overflow-hidden bg-slate/10">
        <iframe
          src={siteData.googleMapsEmbedUrl}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Sushi Monster locations on Google Maps"
          class="w-full h-full"
        ></iframe>
      </div>

      <!-- Info -->
      <div>
        <h2 class="font-display text-3xl md:text-4xl text-deep-navy mb-4">Find Your Monster</h2>
        <p class="text-slate text-lg mb-6">
          4 locations across Kuala Lumpur. Same menu, same prices, same monster appetite.
        </p>
        <div class="space-y-3 text-slate mb-6">
          <p class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-wasabi-green"></span>
            <span>Setapak Central — Flagship</span>
          </p>
          <p class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-monster-coral"></span>
            <span>The Gardens Mall — Mid Valley</span>
          </p>
          <p class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-gold"></span>
            <span>Bangsar Shopping Centre</span>
          </p>
          <p class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-deep-navy"></span>
            <span>Vipod Residences — KLCC</span>
          </p>
        </div>
        <Button href="/locations" variant="outline">View All Locations →</Button>
      </div>
    </div>
  </Container>
</section>
