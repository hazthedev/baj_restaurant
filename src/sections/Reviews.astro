---
import Container from '../components/Container.astro';
import reviewsData from '../data/reviews.json';

function getStars(rating: number) {
  return '⭐'.repeat(rating);
}
---

<section class="py-20 md:py-28 bg-cream">
  <Container>
    <div class="text-center max-w-3xl mx-auto mb-12">
      <h2 class="font-display text-4xl md:text-5xl text-ink-black">
        4.5 / 5 from 1,200+ Google reviewers
      </h2>
      <p class="text-soy-brown text-lg mt-4">
        Most of them came for the cheese bak kut teh. Most of them came back for something else.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {reviewsData.map((review) => (
        <div class="bg-bone-white p-6 rounded-xl">
          <div class="text-xl mb-2">{getStars(review.rating)}</div>
          <p class="text-ink-black text-base leading-relaxed mb-4">
            "{review.quote}"
          </p>
          <div class="text-soy-brown text-sm">
            <span class="font-semibold text-ink-black">{review.name}</span>
            <span class="mx-2">·</span>
            <span>{review.date}</span>
          </div>
        </div>
      ))}
    </div>
  </Container>
</section>
