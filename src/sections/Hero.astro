---
import Button from '../components/Button.astro';
import Container from '../components/Container.astro';
import Eyebrow from '../components/Eyebrow.astro';
---

<section class="min-h-[90vh] flex items-center py-16 md:py-24">
  <Container className="w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
      <!-- Text -->
      <div class="order-2 lg:order-1">
        <Eyebrow>SETAPAK · CHINESE-MALAYSIAN · SINCE 2018</Eyebrow>
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-ink-black mt-4 leading-[1.1]">
          The cheese bak kut teh place.
        </h1>
        <p class="text-soy-brown text-lg md:text-xl mt-6 max-w-lg leading-relaxed">
          We invented it in 2018. Drove SETHLUI, Bangsar Babe, and 1,200+ Google reviewers to climb the wet market stairs. Worth the trip — promise.
        </p>
        <div class="flex flex-wrap gap-4 mt-8">
          <Button href="/menu">See the Menu</Button>
          <Button href="/story" variant="outline">How to Find Us</Button>
        </div>
        <p class="font-accent text-2xl md:text-3xl text-cheese-yellow mt-8 -rotate-2 inline-block">
          since 2018 · 1,200+ ⭐⭐⭐⭐⭐
        </p>
      </div>

      <!-- Image -->
      <div class="order-1 lg:order-2">
        <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-bkt-brown/10">
          <img
            src="https://images.unsplash.com/photo-1569718212165-3a8278d5f624?w=800&h=600&fit=crop"
            alt="Cheese Bak Kut Teh in a claypot — melted cheese on top of herbal pork broth with okra"
            class="w-full h-full object-cover"
            loading="eager"
          />
        </div>
      </div>
    </div>
  </Container>
</section>
