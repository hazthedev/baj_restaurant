---
import Button from '../components/Button.astro';
import Container from '../components/Container.astro';
import Eyebrow from '../components/Eyebrow.astro';
---

<section class="min-h-[90vh] flex items-center py-16 md:py-24 bg-soft-white">
  <Container className="w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
      <!-- Text -->
      <div class="order-2 lg:order-1">
        <div class="inline-flex items-center gap-2 mb-4">
          <span class="bg-wasabi-green text-white text-xs font-bold px-2 py-1 rounded">HALAL</span>
          <Eyebrow>4 LOCATIONS · SINCE 2019</Eyebrow>
        </div>
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl text-deep-navy mt-4 leading-[1.1]">
          Eat like a monster.<br/>
          <span class="text-monster-coral">Pay like a guppy.</span>
        </h1>
        <p class="text-slate text-lg md:text-xl mt-6 max-w-lg leading-relaxed">
          Halal Japanese sushi from RM1.90. Now in 4 KL malls — Setapak, Gardens, Bangsar, Vipod.
        </p>
        <div class="flex flex-wrap gap-4 mt-8">
          <Button href="/menu">See the Menu</Button>
          <Button href="/locations" variant="outline">Find a Location</Button>
        </div>
        <p class="font-accent text-2xl md:text-3xl text-monster-coral mt-8 -rotate-3 inline-block">
          from RM1.90 · 100% pork-free
        </p>
      </div>

      <!-- Icon Tile -->
      <div class="order-1 lg:order-2">
        <div class="aspect-[4/3] rounded-2xl flex items-center justify-center bg-gradient-to-br from-monster-coral/15 via-cheese-yellow/15 to-wasabi-green/10 relative overflow-hidden">
          <div class="absolute inset-0 opacity-10 text-[24rem] flex items-center justify-center select-none" aria-hidden="true">🍣</div>
          <div class="relative text-center">
            <div class="text-9xl md:text-[10rem] select-none" aria-hidden="true">🍣</div>
            <div class="font-accent text-2xl text-monster-coral mt-2 -rotate-2 inline-block">eat the monster</div>
          </div>
        </div>
      </div>
    </div>
  </Container>
</section>
