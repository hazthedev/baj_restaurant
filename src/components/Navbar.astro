---
import Container from '../components/Container.astro';

interface Props {
  currentPage?: 'home' | 'menu' | 'locations';
}

const { currentPage = 'home' } = Astro.props;
const whatsappNumber = '+60 14-372 2425';
---

<nav class="sticky top-0 z-50 bg-soft-white/90 backdrop-blur-md border-b border-slate/10 transition-all duration-300 ease-out" id="navbar">
  <Container>
    <div class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2">
        <span class="text-2xl">🍣</span>
        <div class="flex flex-col">
          <span class="font-display text-2xl md:text-3xl text-deep-navy leading-none">Sushi Monster</span>
          <span class="text-[10px] uppercase tracking-wider text-slate mt-0.5">Halal · 4 Locations · Since 2019</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <a href="/" class={`text-sm font-medium transition-colors duration-300 ease-out ${currentPage === 'home' ? 'text-monster-coral' : 'text-slate hover:text-deep-navy'}`}>
          Home
        </a>
        <a href="/menu" class={`text-sm font-medium transition-colors duration-300 ease-out ${currentPage === 'menu' ? 'text-monster-coral' : 'text-slate hover:text-deep-navy'}`}>
          Menu
        </a>
        <a href="/locations" class={`text-sm font-medium transition-colors duration-300 ease-out ${currentPage === 'locations' ? 'text-monster-coral' : 'text-slate hover:text-deep-navy'}`}>
          Locations
        </a>
        <div class="flex items-center gap-2">
          <span class="bg-wasabi-green text-white text-xs font-bold px-2 py-1 rounded">HALAL</span>
          <a
            href={`https://wa.me/${whatsappNumber.replace(/\s/g, '')}`}
            target="_blank"
            rel="noopener"
            class="bg-monster-coral text-white px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 ease-out hover:bg-salmon-red hover:scale-[1.03]"
          >
            WhatsApp
          </a>
        </div>
      </div>

      <!-- Mobile Menu Button -->
      <button class="md:hidden p-2" id="mobile-menu-btn" aria-label="Toggle menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div class="md:hidden hidden pb-4" id="mobile-menu">
      <div class="flex flex-col gap-4">
        <a href="/" class={`text-sm font-medium transition-colors duration-300 ease-out ${currentPage === 'home' ? 'text-monster-coral' : 'text-slate hover:text-deep-navy'}`}>
          Home
        </a>
        <a href="/menu" class={`text-sm font-medium transition-colors duration-300 ease-out ${currentPage === 'menu' ? 'text-monster-coral' : 'text-slate hover:text-deep-navy'}`}>
          Menu
        </a>
        <a href="/locations" class={`text-sm font-medium transition-colors duration-300 ease-out ${currentPage === 'locations' ? 'text-monster-coral' : 'text-slate hover:text-deep-navy'}`}>
          Locations
        </a>
        <div class="flex items-center gap-2">
          <span class="bg-wasabi-green text-white text-xs font-bold px-2 py-1 rounded">HALAL</span>
          <a
            href={`https://wa.me/${whatsappNumber.replace(/\s/g, '')}`}
            target="_blank"
            rel="noopener"
            class="bg-monster-coral text-white px-4 py-2 rounded-full text-sm font-medium transition-all duration-300 ease-out text-center flex-1"
          >
            WhatsApp
          </a>
        </div>
      </div>
    </div>
  </Container>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
