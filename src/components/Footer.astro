---
import Container from '../components/Container.astro';
import siteData from '../data/site.json';

const { name, address, phone, hours, socials, alacarteUrl } = siteData;
---

<footer class="bg-bkt-brown text-cream py-12 md:py-16">
  <Container>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      <!-- Brand -->
      <div>
        <h3 class="font-display text-3xl mb-2">{name}</h3>
        <p class="text-cream/70 text-sm">Above the wet market in Setapak. Since 2018.</p>
      </div>

      <!-- Visit -->
      <div>
        <h4 class="font-semibold mb-3">Visit Us</h4>
        <address class="not-italic text-cream/70 text-sm space-y-1">
          <p>{address}</p>
          <p>Phone: {phone}</p>
        </address>
        <div class="mt-3 text-cream/70 text-sm">
          <p class="font-medium text-cream">Hours</p>
          {Object.entries(hours).map(([day, time]) => (
            <p>{day}: {time}</p>
          ))}
        </div>
      </div>

      <!-- Links -->
      <div>
        <h4 class="font-semibold mb-3">Order & Follow</h4>
        <div class="space-y-2 text-sm">
          <a href={alacarteUrl} target="_blank" rel="noopener" class="block text-cream/70 hover:text-cheese-yellow transition-colors">
            Order on alacarte.my →
          </a>
          {socials?.facebook && (
            <a href={socials.facebook} target="_blank" rel="noopener" class="block text-cream/70 hover:text-cheese-yellow transition-colors">
              Facebook →
            </a>
          )}
          {socials?.instagram && (
            <a href={socials.instagram} target="_blank" rel="noopener" class="block text-cream/70 hover:text-cheese-yellow transition-colors">
              Instagram →
            </a>
          )}
        </div>
      </div>
    </div>

    <div class="mt-8 pt-8 border-t border-cream/20 text-center text-cream/50 text-sm">
      <p>&copy; {new Date().getFullYear()} {name}. All rights reserved.</p>
    </div>
  </Container>
</footer>
