---
interface Props {
  name: string;
  chineseName?: string;
  description: string;
  price: string;
  image?: string;
  signature?: boolean;
  featuredIn?: string;
  className?: string;
}

const { name, chineseName, description, price, image, signature = false, featuredIn, className = '' } = Astro.props;
---

<div class={`bg-cream rounded-lg overflow-hidden transition-all duration-300 ease-out will-change-transform hover:-translate-y-1.5 hover:shadow-xl hover:shadow-cheese-yellow/15 ${className}`}>
  {image && (
    <div class="aspect-[4/3] overflow-hidden">
      <img
        src={image}
        alt={name}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-2">
      <div class="flex-1">
        <h3 class="font-display text-xl text-ink-black">{name}</h3>
        {chineseName && (
          <p class="text-soy-brown/60 text-sm mt-0.5">{chineseName}</p>
        )}
      </div>
      <span class="font-semibold text-ink-black whitespace-nowrap">{price}</span>
    </div>
    <p class="text-soy-brown text-sm">{description}</p>
    {signature && (
      <div class="mt-3 inline-flex items-center gap-1 bg-cheese-yellow/20 text-bkt-brown text-xs font-medium px-2 py-1 rounded">
        <span>🧀</span>
        <span>Signature</span>
      </div>
    )}
    {featuredIn && (
      <div class="mt-2 text-xs text-soy-brown">
        Featured in <span class="font-semibold">{featuredIn}</span>
      </div>
    )}
  </div>
</div>
