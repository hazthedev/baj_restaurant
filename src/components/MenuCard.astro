---
import TierBadge from './TierBadge.astro';

interface Props {
  name: string;
  description: string;
  price: string;
  icon?: string;
  signature?: boolean;
  featuredIn?: string;
  tier?: 'green' | 'red' | 'gold' | 'special';
  className?: string;
}

const { name, description, price, icon, signature = false, featuredIn, tier, className = '' } = Astro.props;

const tierTile: Record<string, string> = {
  green: 'bg-gradient-to-br from-wasabi-green/15 to-wasabi-green/5',
  red: 'bg-gradient-to-br from-salmon-red/15 to-monster-coral/5',
  gold: 'bg-gradient-to-br from-gold/20 to-gold/5',
  special: 'bg-gradient-to-br from-monster-coral/15 to-deep-navy/5',
};
const tile = tier ? tierTile[tier] : 'bg-gradient-to-br from-cream to-cheese-yellow/10';
---

<div class={`bg-cream rounded-lg overflow-hidden transition-all duration-300 ease-out will-change-transform hover:-translate-y-1.5 hover:shadow-xl hover:shadow-cheese-yellow/15 ${className}`}>
  {icon && (
    <div class={`aspect-[4/3] flex items-center justify-center ${tile}`}>
      <span class="text-7xl md:text-8xl select-none" aria-hidden="true">{icon}</span>
    </div>
  )}
  <div class="p-4">
    <div class="flex items-start justify-between gap-2 mb-2">
      <div class="flex-1">
        <h3 class="font-display text-xl text-ink-black">{name}</h3>
      </div>
      <span class="font-semibold text-ink-black whitespace-nowrap">{price}</span>
    </div>
    <p class="text-soy-brown text-sm">{description}</p>
    <div class="mt-3 flex flex-wrap gap-2">
      {tier && <TierBadge tier={tier} />}
      {signature && (
        <span class="inline-flex items-center gap-1 bg-monster-coral/20 text-monster-coral text-xs font-medium px-2 py-1 rounded-full">
          <span>🍣</span>
          <span>Signature</span>
        </span>
      )}
    </div>
    {featuredIn && (
      <div class="mt-2 text-xs text-soy-brown">
        Featured in <span class="font-semibold">{featuredIn}</span>
      </div>
    )}
  </div>
</div>
