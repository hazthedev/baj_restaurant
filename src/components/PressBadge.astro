---
interface Props {
  name: string;
  quote?: string;
  url?: string;
  className?: string;
}

const { name, quote, url, className = '' } = Astro.props;
---

<div class={`bg-soft-white p-4 rounded-lg ${className}`}>
  <h4 class="font-display text-lg text-deep-navy mb-1">{name}</h4>
  {quote && <p class="text-slate text-sm italic">"{quote}"</p>}
  {url && (
    <a
      href={url}
      target="_blank"
      rel="noopener"
      class="mt-2 inline-block text-monster-coral hover:text-salmon-red text-sm font-medium"
    >
      Read more →
    </a>
  )}
</div>
