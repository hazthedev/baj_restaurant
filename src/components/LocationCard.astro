---
import Button from './Button.astro';

interface Props {
  id: string;
  name: string;
  tag: string;
  lot: string;
  floor: string;
  address: string;
  phone: string;
  hours: string;
  googleMapsEmbedUrl: string;
  foodpandaUrl: string;
  icon?: string;
}

const { id, name, tag, lot, floor, address, phone, hours, googleMapsEmbedUrl, foodpandaUrl, icon = '📍' } = Astro.props;
---

<div id={id} class="scroll-mt-24">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
    <!-- Icon Tile -->
    <div class="aspect-[4/3] rounded-2xl flex items-center justify-center bg-gradient-to-br from-deep-navy/5 via-monster-coral/10 to-cheese-yellow/15">
      <div class="text-center">
        <div class="text-8xl md:text-9xl select-none mb-4" aria-hidden="true">{icon}</div>
        <div class="font-display text-2xl md:text-3xl text-deep-navy">{name}</div>
        <div class="text-slate text-sm mt-1">{floor}, {lot}</div>
      </div>
    </div>

    <!-- Details -->
    <div>
      <div class="flex items-center gap-3 mb-2">
        <span class="bg-monster-coral text-white text-xs font-bold px-2 py-1 rounded-full">
          {tag}
        </span>
      </div>
      <h3 class="font-display text-3xl md:text-4xl text-deep-navy mb-2">{name}</h3>
      <p class="text-slate text-lg mb-4">{floor}, {lot}</p>

      <address class="not-italic text-slate mb-4">
        {address}
      </address>

      <div class="space-y-2 text-slate mb-6">
        <p><span class="font-semibold text-deep-navy">Hours:</span> {hours}</p>
        <p><span class="font-semibold text-deep-navy">Phone:</span> {phone}</p>
      </div>

      <!-- Small Map -->
      <div class="aspect-video rounded-xl overflow-hidden bg-slate/10 mb-6">
        <iframe
          src={googleMapsEmbedUrl}
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title={`${name} location on Google Maps`}
          class="w-full h-full"
        ></iframe>
      </div>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3">
        <Button href={`https://maps.google.com/?q=${encodeURIComponent(address)}`}>
          Get Directions
        </Button>
        <Button href={foodpandaUrl} variant="outline">
          Order on FoodPanda
        </Button>
      </div>
    </div>
  </div>
</div>
