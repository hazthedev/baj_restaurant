---
interface Props {
  href: string;
  variant?: 'primary' | 'outline' | 'ghost';
  children: any;
  className?: string;
}

const { href, variant = 'primary', children, className = '' } = Astro.props;

const variants = {
  primary: 'bg-monster-coral text-white hover:bg-salmon-red',
  outline: 'border-2 border-deep-navy text-deep-navy hover:bg-deep-navy hover:text-white',
  ghost: 'text-slate hover:text-deep-navy',
};
---

<a
  href={href}
  class={`inline-flex items-center justify-center px-6 py-3 font-medium rounded-lg transition-all duration-300 ease-out will-change-transform hover:scale-[1.02] active:scale-[0.98] ${variants[variant]} ${className}`}
>
  <slot>{children}</slot>
</a>
