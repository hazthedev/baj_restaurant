---
interface Props {
  href: string;
  variant?: 'primary' | 'outline' | 'ghost';
  children: any;
  className?: string;
}

const { href, variant = 'primary', children, className = '' } = Astro.props;

const variants = {
  primary: 'bg-cheese-yellow text-ink-black hover:bg-soft-mustard',
  outline: 'border-2 border-ink-black text-ink-black hover:bg-ink-black hover:text-bone-white',
  ghost: 'text-soy-brown hover:text-ink-black',
};
---

<a
  href={href}
  class={`inline-flex items-center justify-center px-6 py-3 font-medium transition-all duration-250 ${variants[variant]} ${className}`}
>
  <slot>{children}</slot>
</a>
