---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/Container.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Page Not Found | B.A.J Restaurant Setapak">
  <Container className="min-h-[70vh] flex items-center justify-center py-20">
    <div class="text-center">
      <h1 class="font-display text-6xl md:text-8xl text-cheese-yellow mb-4">404</h1>
      <h2 class="font-display text-2xl md:text-3xl text-ink-black mb-4">Lost above the wet market?</h2>
      <p class="text-soy-brown text-lg mb-8 max-w-md mx-auto">
        This page doesn't exist. Head back to the main menu — the cheese bak kut teh is waiting.
      </p>
      <Button href="/">Back to Home</Button>
    </div>
  </Container>
</BaseLayout>
