---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
import Container from '../components/Container.astro';
import Eyebrow from '../components/Eyebrow.astro';
import ContactForm from '../components/ContactForm';
import siteData from '../data/site.json';

const { address, phone, hours, socials, googleMapsEmbedUrl, alacarteUrl } = siteData;
---

<BaseLayout
  title="Our Story & Visit Us | B.A.J Restaurant Setapak | Since 2018"
  description="How we ended up famous for cheese bak kut teh. The 2018 experiment, the wet market location, and the crowd that made it happen. Visit us above Pasar Setapak."
>
  <Navbar currentPage="story" />

  <main>
    <!-- Story Hero -->
    <section class="py-16 md:py-24">
      <Container>
        <div class="text-center max-w-3xl mx-auto">
          <Eyebrow>OUR STORY</Eyebrow>
          <h1 class="font-display text-4xl md:text-5xl lg:text-6xl text-ink-black mt-4">
            How we ended up famous for cheese bak kut teh.
          </h1>
          <p class="text-soy-brown text-lg md:text-xl mt-6 leading-relaxed">
            Started with an experiment in 2018. Ended up on SETHLUI. Long story — short version: melted cheese on bak kut teh works better than it should.
          </p>
        </div>
      </Container>
    </section>

    <!-- The Beginning -->
    <section class="py-16 md:py-20 bg-cream">
      <Container>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
          <div>
            <Eyebrow>THE BEGINNING</Eyebrow>
            <h2 class="font-display text-3xl md:text-4xl text-ink-black mt-2 mb-4">February 2018</h2>
            <p class="text-soy-brown text-lg leading-relaxed mb-4">
              We opened on the 1st floor of Pasar Setapak with a simple idea: serve good, affordable Chinese-Malaysian food to the students and locals who pass through every day.
            </p>
            <p class="text-soy-brown text-lg leading-relaxed">
              The cheese bak kut teh started as an experiment — a crazy idea that maybe melted cheese on herbal pork broth wouldn't be terrible. The first batch went to a table of TAR UMT students. They posted it on Instagram. The rest is history.
            </p>
          </div>
          <div class="aspect-[4/3] rounded-2xl overflow-hidden bg-bkt-brown/10">
            <img
              src="https://images.unsplash.com/photo-1559339352-11d035aa65de?w=800&h=600&fit=crop"
              alt="Cosy casual café interior with wooden tables"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </Container>
    </section>

    <!-- The Dish -->
    <section class="py-16 md:py-20">
      <Container>
        <div class="text-center max-w-3xl mx-auto mb-12">
          <Eyebrow>THE DISH</Eyebrow>
          <h2 class="font-display text-3xl md:text-4xl text-ink-black mt-2">Cheese Bak Kut Teh: The Process</h2>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-4xl mx-auto">
          {[
            { step: '1', title: 'Claypot', desc: 'Heated over open flame' },
            { step: '2', title: 'Okra', desc: 'Fresh slices added first' },
            { step: '3', title: 'Pork & Broth', desc: 'Herbal broth simmers' },
            { step: '4', title: 'Cheese', desc: 'Melted on top to finish' },
          ].map((item) => (
            <div class="text-center">
              <div class="w-12 h-12 rounded-full bg-cheese-yellow flex items-center justify-center text-ink-black font-display text-xl mx-auto mb-3">
                {item.step}
              </div>
              <h3 class="font-display text-lg text-ink-black">{item.title}</h3>
              <p class="text-soy-brown text-sm mt-1">{item.desc}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- The Place -->
    <section class="py-16 md:py-20 bg-bkt-brown">
      <Container>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-center">
          <div class="order-2 lg:order-1 aspect-[4/3] rounded-2xl overflow-hidden">
            <img
              src="https://images.unsplash.com/photo-1533900298318-6b8da08a523e?w=800&h=600&fit=crop"
              alt="Wet market stairs leading up to the restaurant"
              class="w-full h-full object-cover"
              loading="lazy"
            />
          </div>
          <div class="order-1 lg:order-2">
            <Eyebrow className="text-cream/70">THE PLACE</Eyebrow>
            <h2 class="font-display text-3xl md:text-4xl text-cream mt-2 mb-4">Above the Wet Market</h2>
            <p class="text-cream/70 text-lg leading-relaxed mb-4">
              Most restaurants would hide the fact that they're above a wet market. We think it's the best part.
            </p>
            <p class="text-cream/70 text-lg leading-relaxed">
              The market closes by evening. The restaurant goes till 10pm. Take the stairs up to the 1st floor, follow the smell of cheese bak kut teh. You can't miss us.
            </p>
          </div>
        </div>
      </Container>
    </section>

    <!-- The Crowd -->
    <section class="py-16 md:py-20 bg-cream">
      <Container>
        <div class="text-center max-w-3xl mx-auto mb-12">
          <Eyebrow>THE CROWD</Eyebrow>
          <h2 class="font-display text-3xl md:text-4xl text-ink-black mt-2">Who Comes Here</h2>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-4xl mx-auto">
          {[
            { title: 'TAR UMT Students', desc: 'Our bread and butter. They come for the RM3.90 economy rice and stay for the cheese BKT.' },
            { title: 'Food Bloggers', desc: 'SETHLUI, Bangsar Babe, and more. They drove here for the cheese pull. They came back for everything else.' },
            { title: 'Late-Night Regulars', desc: 'Supper crowd rolls in after 9pm. The BKT pot stays warm. The conversations get louder.' },
          ].map((item) => (
            <div class="bg-bone-white p-6 rounded-xl text-center">
              <h3 class="font-display text-xl text-ink-black mb-2">{item.title}</h3>
              <p class="text-soy-brown text-sm leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
      </Container>
    </section>

    <!-- Visit Us -->
    <section class="py-16 md:py-20">
      <Container>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16">
          <!-- Map -->
          <div class="aspect-video lg:aspect-auto lg:h-full min-h-[300px] rounded-2xl overflow-hidden bg-soy-brown/10">
            <iframe
              src={googleMapsEmbedUrl}
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="B.A.J Restaurant location on Google Maps"
              class="w-full h-full"
            ></iframe>
          </div>

          <!-- Info -->
          <div>
            <Eyebrow>VISIT US</Eyebrow>
            <h2 class="font-display text-3xl md:text-4xl text-ink-black mt-2 mb-6">Find the Stairs</h2>
            
            <div class="space-y-6">
              <div>
                <h3 class="font-semibold text-ink-black mb-1">Address</h3>
                <p class="text-soy-brown">{address}</p>
                <p class="text-soy-brown text-sm mt-1">1st floor, above Pasar Setapak wet market</p>
              </div>

              <div>
                <h3 class="font-semibold text-ink-black mb-1">Phone</h3>
                <p class="text-soy-brown">{phone}</p>
              </div>

              <div>
                <h3 class="font-semibold text-ink-black mb-1">Hours</h3>
                <div class="text-soy-brown text-sm space-y-1">
                  {Object.entries(hours).map(([day, time]) => (
                    <p><span class="inline-block w-24">{day}:</span> {time}</p>
                  ))}
                </div>
              </div>

              <div>
                <h3 class="font-semibold text-ink-black mb-1">Parking</h3>
                <p class="text-soy-brown text-sm">Street parking available around Pasar Setapak. Best to come before 6pm for easier spots.</p>
              </div>

              <div class="bg-cream p-4 rounded-lg">
                <p class="font-accent text-xl text-cheese-yellow -rotate-1">
                  "The stairs are at the side of the wet market. 1st floor. You can't miss us — we're the one with the cheese smell."
                </p>
              </div>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <!-- Contact Form -->
    <section class="py-16 md:py-20 bg-cream">
      <Container>
        <div class="max-w-xl mx-auto">
          <div class="text-center mb-8">
            <Eyebrow>GET IN TOUCH</Eyebrow>
            <h2 class="font-display text-3xl md:text-4xl text-ink-black mt-2">Send us a message</h2>
            <p class="text-soy-brown mt-3">For pre-orders, large groups, or just to say hi.</p>
          </div>
          <ContactForm client:load />
        </div>
      </Container>
    </section>

    <!-- Social Block -->
    <section class="py-12 md:py-16">
      <Container>
        <div class="text-center">
          <h2 class="font-display text-2xl md:text-3xl text-ink-black mb-4">Follow Us</h2>
          <div class="flex justify-center gap-4">
            {socials?.facebook && (
              <a
                href={socials.facebook}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 bg-cheese-yellow text-ink-black px-6 py-3 rounded-full font-medium hover:bg-soft-mustard transition-colors"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Facebook
              </a>
            )}
            <a
              href={`https://wa.me/${siteData.whatsapp}`}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 border-2 border-ink-black text-ink-black px-6 py-3 rounded-full font-medium hover:bg-ink-black hover:text-bone-white transition-colors"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/>
              </svg>
              WhatsApp
            </a>
          </div>
        </div>
      </Container>
    </section>
  </main>

  <Footer />
  <WhatsAppFloat />
</BaseLayout>
